FLASK_ENV=development
SECRET_KEY=troque-esta-chave-em-producao
DATABASE_URL=postgresql://usuario:senha@localhost:5432/escala_medica

# Módulo de reuniões — LiveKit (videochamada ao vivo) e DeepSeek (geração da ata)
# Preencha os valores reais APENAS no .env (que é ignorado pelo git), nunca aqui.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_WS_URL=wss://seu-projeto.livekit.cloud
DEEPSEEK_API_KEY=

# Liga o módulo de reuniões (default desligado: item aparece no menu, mas desativado)
# REUNIOES_ENABLED=true

# Opcional: sobrescrever local das gravações e limite de upload por requisição (bytes)
# GRAVACOES_DIR=/root/projetos/escala-medica/gravacoes
# MAX_CONTENT_LENGTH=10485760
